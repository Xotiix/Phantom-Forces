			local function reshuffle()
				shuffleBag = {}

				for i = 1, #soundIds do
					table.insert(shuffleBag, soundIds[i])
				end

				-- Fisher-Yates shuffle
				for i = #shuffleBag, 2, -1 do
					local j = math.random(1, i)
					shuffleBag[i], shuffleBag[j] = shuffleBag[j], shuffleBag[i]
				end

				-- 🔥 prevent same sound at cycle boundary
				if lastPlayed and shuffleBag[1] == lastPlayed then
					local swapIndex = math.random(2, #shuffleBag)
					shuffleBag[1], shuffleBag[swapIndex] = shuffleBag[swapIndex], shuffleBag[1]
				end
			end
