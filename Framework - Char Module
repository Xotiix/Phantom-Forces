		-- Equip (weighty but responsive)
		equipspring.s    = 9
		equipspring.d    = 1.0

		-- Sprint / Aim (firm, no bounce)
		sprintspring.s   = 10
		sprintspring.d   = 1.05
		aimspring.d      = 1.1

		-- Body / camera swing (Marathon feel)
		swingspring.s    = 12
		swingspring.d    = 1.0

		-- Movement inertia
		speedspring.s    = 12
		speedspring.d    = 1.0

		velocityspring.s = 12
		velocityspring.d = 1.05

		pronespring.s    = 6
		pronespring.d    = 1.1

		truespeedspring.s = 6
		truespeedspring.d = 1.1

		-- Muzzle: stiff + dead (no wobble)
		muzzlespring.s   = 45
		muzzlespring.d   = 1.25

		-- Walkspeed & head height
		walkspeedspring  = physics.spring.new(basewalkspeed)
		walkspeedspring.s = 7
		walkspeedspring.d = 1.0

		headheightspring = physics.spring.new(1.5)
		headheightspring.s = 7
		headheightspring.d = 1.0 

		if muzzlelight then
			muzzlelight:Destroy()
