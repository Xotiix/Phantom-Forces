	function char.addgun(gundata)
		for i = 1, curgunid do
			if loadedgundata[i] == gundata then
				error("Error, tried to add gun twice")
				break
			end
		end
		curgunid = curgunid + 1
		loadedgundata[curgunid] = gundata
		gundata.id = curgunid
		return curgunid
	end
	function char.removegun(gundata)
		local found
		for i = 1, curgunid do
			if loadedgundata[i] == gundata then
				found = true
				break
			end
		end
		if not found then
			error("Error, tried to remove gun twice")
		end
		local gunid = gundata.id
		gundata.id = nil
		loadedgundata[gunid] = loadedgundata[curgunid]
		loadedgundata[curgunid] = nil
		curgunid = curgunid - 1
		local replacement = loadedgundata[gunid]
		if replacement then
			replacement.id = gunid
		end
	end
	function char.unloadguns()
