				if dive and sprinting and rootpart.Velocity.Y > -5 then
					task.spawn(function()
						local camCF = camera.currentcamera.CFrame

						-- READ INPUT
						local inputDir = Vector3.zero
						if input.keyboard.down.w then inputDir += camCF.LookVector end
						if input.keyboard.down.s then inputDir -= camCF.LookVector end
						if input.keyboard.down.a then inputDir -= camCF.RightVector end
						if input.keyboard.down.d then inputDir += camCF.RightVector end

						-- FLATTEN DIRECTION (NO PITCH)
						local rawDir =
							(inputDir.Magnitude > 0 and inputDir)
							or camCF.LookVector

						local jumpDir = Vector3.new(rawDir.X, 0, rawDir.Z).Unit

						-- PHASE 1: SNAP
						rootpart.Velocity =
							jumpDir * (72 * loltimescale)
							+ Vector3.new(0, 52 * loltimescale, 0)

						-- PHASE 2: ASSIST
						task.wait(0.11 / loltimescale)
						rootpart.Velocity =
							jumpDir * (48 * loltimescale)
							+ Vector3.new(0, 34 * loltimescale, 0)

						-- PHASE 3: APEX HOLD
						task.wait(0.14 / loltimescale)
						rootpart.Velocity =
							jumpDir * (40 * loltimescale)
							+ Vector3.new(0, 10 * loltimescale, 0)

						-- PHASE 4: DROP
						task.wait(0.20 / loltimescale)
						rootpart.Velocity =
							jumpDir * (18 * loltimescale)
							+ Vector3.new(0, -18 * loltimescale, 0)
					end)
				end
			elseif mode == "crouch" then
				if not dive and oldmode ~= mode then
					sound.play("stanceStandCrouch", 0.15)
				end

				headheightspring.t = 0
				rootjoint.C0 = crouchcf
				pronespring.t = 0
				walkspeedspring.t = walkspeedmult * basewalkspeed / 2
				hud:setcrossscale(0.75)
				stability = 0.25

				if dive and sprinting and humanoid:GetState() ~= Enum.HumanoidStateType.Freefall then 
					isSliding = true
					sound.play("slideStart", 0.25)

					task.spawn(function()
						-- Strong horizontal bite, limited vertical
						bodyforce.MaxForce = Vector3.new(110000, 35, 110000)

						local camCF = camera.currentcamera.CFrame

						-- START FROM REAL VELOCITY (momentum)
						local slideVel = rootpart.AssemblyLinearVelocity

						-- HARD ENTRY PUNCH (Marathon-style)
						slideVel += camCF.LookVector * 18

						-- Steering (heavy, resistant)
						local steerStrength = 0.08

						-- Speed control
						local speed = math.max(slideVel.Magnitude, 55)

						for i = 1, 28 do
							if not isSliding then break end

							local camCF = camera.currentcamera.CFrame
							local moveDir = Vector3.zero

							if input.keyboard.down.w then moveDir += camCF.LookVector end
							if input.keyboard.down.s then moveDir -= camCF.LookVector end
							if input.keyboard.down.a then moveDir -= camCF.RightVector end
							if input.keyboard.down.d then moveDir += camCF.RightVector end

							if moveDir.Magnitude > 0 then
								-- HARD snap velocity direction to input intent (kills forward creep)
								slideVel = moveDir.Unit * slideVel.Magnitude
							else
								-- No input → preserve current slide direction
								slideVel = slideVel
							end

							-- NONLINEAR DECAY (front-loaded loss, long tail)
							if i < 6 then
								speed -= 2.2   -- punch bleeds fast
							else
								speed -= 0.9   -- gritty crawl
							end

							speed = math.max(speed, 10)

							bodyforce.Velocity = slideVel.Unit * speed
							task.wait(1/60)
						end

						-- Release force WITHOUT snapping
						bodyforce.MaxForce = Vector3.zero
						bodyforce.Velocity = Vector3.zero

						if isSliding then
							isSliding = false
							sound.play("slideEnd", 0.15)

							-- Exit keeps grit, no boost
							rootpart.Velocity =
								slideVel.Unit * math.max(speed * 0.45, 14)
								+ Vector3.new(0, rootpart.Velocity.Y, 0)
						end
					end)
				end
			elseif mode == "stand" then
				if oldmode ~= mode then
					sound.play("stanceStandCrouch", 0.15)
				end
				headheightspring.t = 1.5
				rootjoint.C0=standcf
				pronespring.t = 0
				walkspeedspring.t = walkspeedmult * basewalkspeed
				hud:setcrossscale(1)
				stability = 0
			end
			network:bounce("stance",player,mode)
			sprinting=false
			network:bounce("sprint",player,sprinting)
			sprintspring.t=0
		end
