							local mesh = new("BlockMesh")
							mesh.Parent = trail
							mesh.Scale = v3(
								0.35,
								0.35,
								dist * 3
							)

							debris:AddItem(trail, 0.25)

							lasttrailpos = position
							lasttrailt = time
						end
						flyingnade.CFrame=cf(position+offset)*cframe.fromaxisangle(t*av0)*rot0
					else
						explode()
					end
				end

			end)

