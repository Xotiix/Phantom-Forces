	local usedUniformsGlobal = {}
	local lastUniformEquipped = {}

	local function CanUseUniform(player, uniformName)
		local props = UniformProperties[uniformName]
		if not props then return true end

		if not ALLOW_ALL_SEASONS and props.season and props.season ~= CURRENT_SEASON then
			return false
		end

		if props.reservedFor then
			for _,name in ipairs(props.reservedFor) do
				if player.Name == name then
					return true
				end
			end
			return false
		end

		return true
	end

	local function PickUniqueUniform(player, folder)
		local candidates = {}

		for _,set in ipairs(folder:GetChildren()) do
			local props = UniformProperties[set.Name]
			local canUse = CanUseUniform(player, set.Name)
			local notUsedOrReserved = not usedUniformsGlobal[set.Name] or (props and props.reservedFor and table.find(props.reservedFor, player.Name))
			if canUse and notUsedOrReserved then
				local weight = (UniformProperties[set.Name] and UniformProperties[set.Name].rarity) or Rarity.STANDARD
				for i=1,weight do table.insert(candidates,set) end
			end
		end

		if #candidates == 0 then
			usedUniformsGlobal = {}
			return PickUniqueUniform(player, folder)
		end

		local chosen = candidates[math.random(1,#candidates)]
		usedUniformsGlobal[chosen.Name] = player.Name
		return chosen
	end

	local function GetPreviousUniform(player, folder)
		local last = lastUniformEquipped[player.UserId]
		if last and folder:FindFirstChild(last) and not usedUniformsGlobal[last] then
			usedUniformsGlobal[last] = player.Name
			return folder[last]
		end
		return nil
	end

