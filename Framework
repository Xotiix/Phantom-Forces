event = event or {}

do
	--------------------------------------------------------
	-- FAST LOCALS
	--------------------------------------------------------
	local spawn = task.spawn
	local xpcall = xpcall
	local traceback = debug.traceback

	--------------------------------------------------------
	-- CREATE EVENT
	--------------------------------------------------------
	function event.new(eventtable)
		local self = eventtable or {}
		local listeners = {}
		local removed = {}

		----------------------------------------------------
		-- connect
		----------------------------------------------------
		function self:connect(func)
			listeners[#listeners + 1] = func
			local disconnected = false

			local function disconnect()
				if not disconnected then
					disconnected = true
					removed[func] = true
				end
			end

			return disconnect
		end

		----------------------------------------------------
		-- fire
		----------------------------------------------------
		local function fire(...)
			-- compact listener list
			local write = 1
			for read = 1, #listeners do
				local fn = listeners[read]
				if not removed[fn] then
					listeners[write] = fn
					write += 1
				else
					removed[fn] = nil
				end
			end

			for i = write, #listeners do
				listeners[i] = nil
			end

			-- dispatch (async, safe)
			for i = 1, write - 1 do
				local fn = listeners[i]
				spawn(function(...)
					local ok, err = xpcall(fn, traceback, ...)
					if not ok then
						warn("[event] listener error:\n" .. err)
					end
				end, ...)
			end
		end

		return fire, self
	end
end

















-- sequencer script
-- By AxisAngle (Trey Reynolds)

print("Loading sequencer module")

------------------------------------------------------------
-- GLOBAL TABLE
------------------------------------------------------------
sequencer = sequencer or {}

do
	--------------------------------------------------------
	-- FAST LOCALS
	--------------------------------------------------------
	local clock = os.clock

	--------------------------------------------------------
	-- CREATE SEQUENCER
	--------------------------------------------------------
	function sequencer.new()
		local self = {}

		local t0
		local sequence = {}
		local n = 0
		local deletions = 0

		----------------------------------------------------
		-- add function step
		----------------------------------------------------
		function self:add(func, dur)
			n += 1
			if n == 1 then
				t0 = clock()
			end
			sequence[n] = {
				func = func,
				dur = dur,
			}
		end

		----------------------------------------------------
		-- add delay step
		----------------------------------------------------
		function self:delay(dur)
			n += 1
			if n == 1 then
				t0 = clock()
			end
			sequence[n] = {
				dur = dur,
			}
		end

		----------------------------------------------------
		-- clear sequence
		----------------------------------------------------
		function self:clear()
			for i = 1, n do
				sequence[i] = nil
			end
			deletions = 0
			n = 0
		end

		----------------------------------------------------
		-- step sequencer
		----------------------------------------------------
		function self:step()
			if n == 0 then
				return
			end

			local now = clock()

			-- compact deleted entries
			if deletions ~= 0 then
				for i = deletions + 1, n do
					sequence[i - deletions] = sequence[i]
				end
				for i = n - deletions + 1, n do
					sequence[i] = nil
				end
				n -= deletions
				deletions = 0
			end

			local elapsed = now - t0

			for i = 1, n do
				local entry = sequence[i]
				local stop = false

				if entry.func then
					stop = entry.func(elapsed)
				end

				if stop or stop == nil or (entry.dur and entry.dur < elapsed) then
					t0 = now
					deletions += 1
				else
					break
				end
			end
		end

		return self
	end
end

















