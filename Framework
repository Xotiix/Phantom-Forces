			end

			local camCFrame = CFrame.new(camPos, focusPos)
			camera.currentcamera.CFrame = camCFrame
			camera.cframe = camCFrame
			camera.lookvector = camCFrame.LookVector
			camera.currentcamera.FieldOfView = camera.menufov
		end

