	local ptos = nc.pointToObjectSpace
	local vtos = nc.vectorToObjectSpace
	local vtws = nc.vectorToWorldSpace

	local workspace = game.Workspace
	local getchildren = game.GetChildren
	local isa = game.IsA

	------------------------------------------------------------
	-- MODERN OVERLAP PARAMS
	------------------------------------------------------------
	local overlap = OverlapParams.new()
	overlap.FilterType = Enum.RaycastFilterType.Exclude
	overlap.RespectCanCollide = true

	------------------------------------------------------------
	-- mesh definitions
	------------------------------------------------------------
	local boxmesh = {
		{p=0.5; n=v3(-1,0,0)}, {p=0.5; n=v3(1,0,0)},
		{p=0.5; n=v3(0,-1,0)}, {p=0.5; n=v3(0,1,0)},
		{p=0.5; n=v3(0,0,-1)}, {p=0.5; n=v3(0,0,1)},
	}

	local wedgemesh = {
		{p=0.5; n=v3(-1,0,0)}, {p=0.5; n=v3(1,0,0)},
		{p=0.5; n=v3(0,-1,0)},
		{p=0; n=v3(0,0.5^0.5,-0.5^0.5)},
		{p=0.5; n=v3(0,0,1)},
	}

	local cornerwedgemesh = {
		{p=0.5; n=v3(1,0,0)}, {p=0.5; n=v3(0,-1,0)},
		{p=0.5; n=v3(0,0,-1)},
		{p=0; n=v3(0,0.5^0.5,0.5^0.5)},
		{p=0; n=v3(-0.5^0.5,0.5^0.5,0)},
	}

	------------------------------------------------------------
	-- math solvers (UNCHANGED)
	------------------------------------------------------------
	local function solveplanesphereray(p,n,o,d,r)
		local dn = dot(d,n)
		if dn == 0 then return end
		local t = (p + r - dot(n,o)) / dn
		local v = o + t*d
		return v, t, v - r*n, n
	end

	local function solvepointsphereray(p,o,d,r)
		local b = 2*(dot(o,d)-dot(d,p))
		local c = dot(o,o)-2*dot(o,p)+dot(p,p)-r*r
		local g = -b*0.5
		local e2 = g*g - c
		if e2 > 0 then
			local t = g - math.sqrt(e2)
			local v = o + t*d
			return v, t, p, (v-p)/r
		end
	end

	local function solvespheresphereray(p,e,o,d,r)
		local rr = (r+e)
		local b = 2*(dot(o,d)-dot(d,p))
		local c = dot(o,o)-2*dot(o,p)+dot(p,p)-rr*rr
		local g = -b*0.5
		local e2 = g*g - c
		if e2 > 0 then
			local t = g - math.sqrt(e2)
			local v = o + t*d
			local h = p + e/rr*(v-p)
			return v, t, h, (v-h)/rr
		end
	end

	local function distpointsphereray(p,o,d,r)
		local b = 2*(dot(o,d)-dot(d,p))
		local c = dot(o,o)-2*dot(o,p)+dot(p,p)-r*r
		local g = -b*0.5
		local e2 = g*g - c
		if e2 > 0 then
			return g - math.sqrt(e2)
		end
	end

	local function sortdist(a,b)
		return a.dist < b.dist
	end

	------------------------------------------------------------
	-- mesh solve (unchanged)
	------------------------------------------------------------
	local function solvemeshsphereray(mesh,cframe,scale,origin,dir,radius)
		local o = ptos(cframe,origin)
		local d = vtos(cframe,dir)
		if d.Magnitude < 1e-6 then return end

		for _,pl in ipairs(mesh) do
			local n = (pl.n/scale).Unit
			if dot(n,d) < 0 then
				local p = pl.p / (pl.n/scale).Magnitude
				local v,t,h,nm = solveplanesphereray(p,n,o,d,radius)
				if v and t>0 then
					return cframe*v,t,cframe*h,vtws(cframe,nm)
				end
			end
		end
	end

	local function solvepartsphereray(part,origin,dir,radius)
		local cls = part.ClassName
		if cls=="Part" or cls=="TrussPart" then
			if part.Shape.Name=="Block" then
				return solvemeshsphereray(boxmesh,part.CFrame,part.Size,origin,dir,radius)
			elseif part.Shape.Name=="Ball" or part.Shape.Name=="Cylinder" then
				return solvespheresphereray(part.Position,part.Size.X*0.5,origin,dir,radius)
			end
		elseif cls=="WedgePart" then
			return solvemeshsphereray(wedgemesh,part.CFrame,part.Size,origin,dir,radius)
		elseif cls=="CornerWedgePart" then
			return solvemeshsphereray(cornerwedgemesh,part.CFrame,part.Size,origin,dir,radius)
		end
	end

	------------------------------------------------------------
	-- ignore expansion (unchanged)
	------------------------------------------------------------
	local function expandignore(root,map)
		local stack={root}
		while #stack>0 do
			local obj=table.remove(stack)
			map[obj]=true
			for _,c in ipairs(getchildren(obj)) do
				stack[#stack+1]=c
			end
		end
	end

	------------------------------------------------------------
	-- PUBLIC API (patched broadphase)
	------------------------------------------------------------
	function sphereraycast(origin,direction,radius,ignore,maxdist,filter)
		if direction.Magnitude < 1e-6 then return end

		local ignoremap = {}
		if ignore then
			if type(ignore)=="table" then
				for _,v in ipairs(ignore) do expandignore(v,ignoremap) end
			else
				expandignore(ignore,ignoremap)
			end
		end

		overlap.FilterDescendantsInstances = ignore and
			(type(ignore)=="table" and ignore or {ignore}) or {}

		local len = maxdist or direction.Magnitude
		local dir = direction.Unit
		local t = 0

		repeat
			local step = math.min(testinterval, len-t)
			local center = origin + dir*(t + step*0.5)
			t += step

			local size = v3(radius*2+step, radius*2+step, radius*2+step)
			local parts = workspace:GetPartBoundsInBox(cf(center), size, overlap)

			local cand = {}
			for _,p in ipairs(parts) do
				if not ignoremap[p] and (not filter or filter(p)) then
					ignoremap[p]=true
					local d = distpointsphereray(p.Position,origin,dir,radius+p.Size.Magnitude*0.5)
					if d then
						cand[#cand+1]={part=p,dist=d}
					end
				end
			end

			sort(cand,sortdist)

			for _,pkg in ipairs(cand) do
				if pkg.dist>len then break end
				local pos,dist,hit,norm =
					solvepartsphereray(pkg.part,origin,dir,radius)
				if dist and dist>0 and dist<=len then
					return pkg.part,pos,dist,hit,norm
				end
			end
		until t>=len
	end
end



















