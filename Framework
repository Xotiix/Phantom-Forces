		local function playFootstep(foot)
			if not foot.ignore then return end

			local origin = foot.pos + Vector3.new(0, 1, 0)
			local dir = Vector3.new(0, -3, 0)

			local hit, pos, norm = workspace:FindPartOnRayWithIgnoreList(
