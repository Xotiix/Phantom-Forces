		local gd=noobsdata:GetChildren()
		table.sort(gd,function(a,b)
			return tonumber(a.Score.Text)>tonumber(b.Score.Text)
		end)

		for i=1,#gd do
			local v=gd[i]
			v.Position=ud2(0,0,0,i*spacing)
			if v.Name==player.Name then
				v.Username.TextColor3=color(1,1,0)
