	-- Store original transparency values once
	local originalTransparency = {}

	local function cacheOriginalTransparency(frame)
		if originalTransparency[frame] then return end

		originalTransparency[frame] = {}

		for _, obj in ipairs(frame:GetDescendants()) do
			if obj:IsA("TextLabel") or obj:IsA("TextButton") then
				originalTransparency[frame][obj] = {
					TextTransparency = obj.TextTransparency,
					TextStrokeTransparency = obj.TextStrokeTransparency
				}
			elseif obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
				originalTransparency[frame][obj] = {
					ImageTransparency = obj.ImageTransparency
				}
			elseif obj:IsA("Frame") then
				originalTransparency[frame][obj] = {
					BackgroundTransparency = obj.BackgroundTransparency
				}
			end
		end
	end

	local function restoreTransparency(frame)
		if not originalTransparency[frame] then return end

		for obj, props in pairs(originalTransparency[frame]) do
			for prop, value in pairs(props) do
				obj[prop] = value
			end
		end
	end

	local function fadeOutFrame(frame, duration)
		cacheOriginalTransparency(frame)

		local tweens = {}

		-- Tween all children to transparency = 1
		for obj, props in pairs(originalTransparency[frame]) do
			local goal = {}
			for prop, _ in pairs(props) do
				goal[prop] = 1
			end

			table.insert(tweens, TweenService:Create(
				obj,
				TweenInfo.new(duration, Enum.EasingStyle.Linear),
				goal
				))
		end

		for _, t in ipairs(tweens) do
			t:Play()
		end

		task.wait(duration)
		frame.Visible = false
	end


