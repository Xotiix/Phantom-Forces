	function effects:ejectshell(trigger, guntype, offset)
		local shellpart

		-- POOLING
		if #shelllist > 0 then
			shellpart = shelllist[#shelllist]
			shelllist[#shelllist] = nil
		else
			shellpart = shell:Clone()
		end

		-- POSITION
		local cf = trigger.CFrame * offset
		shellpart.CFrame = cf

		-- PARENT EARLY (important for physics)
		shellpart.Parent = ignore

		-- RANDOMIZED EJECTION DIRECTIONS
		local right = trigger.CFrame.RightVector
		local up = trigger.CFrame.UpVector
		local back = -trigger.CFrame.LookVector

		-- VELOCITY (feels MUCH better than BodyThrust)
		local velocity =
			(right * (6 + random() * 2)) +   -- eject right
			(up * (4 + random() * 2)) +      -- pop upward
			(back * (2 + random()))          -- slight backward kick

		shellpart.AssemblyLinearVelocity = velocity

		-- ROTATION (spin)
		shellpart.AssemblyAngularVelocity = v3(
			random(-20, 20),
			random(-20, 20),
			random(-20, 20)
		)

		-- RANDOM INITIAL TILT
		shellpart.CFrame *= angles(
			math.rad(90 + random(-10, 10)),
			math.rad(random(-10, 10)),
			math.rad(random(-10, 10))
		)

		-- CLEANUP (no wait chains)
		task.delay(0.6, function()
			if shellpart then
				shellpart.AssemblyLinearVelocity = v3()
				shellpart.AssemblyAngularVelocity = v3()
				shellpart.Parent = nil

				shelllist[#shelllist + 1] = shellpart
			end
		end)
	end

	function effects:muzzleflash(barrel, gunData)

		local desired_flash

		--------------------------------------------------
		-- PRIORITY 1: ATTACHMENTS
		--------------------------------------------------

		if gunData.attachdata then
			local muzzleAtt = gunData.attachdata.Muzzle or gunData.attachdata.muzzle

			if muzzleAtt then
				desired_flash = muzzleAtt.MuzzleEffect or muzzleAtt.muzzletype or muzzleTypeMap[gunData.type]
			end
		end

		--------------------------------------------------
		-- PRIORITY 2: GUN OVERRIDE
		--------------------------------------------------

		if not desired_flash and gunData.muzzletype then
			desired_flash = gunData.muzzletype
		end

		--------------------------------------------------
		-- PRIORITY 3: GUN TYPE
		--------------------------------------------------

		if not desired_flash then
			desired_flash = muzzleTypeMap[gunData.type]
		end

		--------------------------------------------------
		-- FINAL FALLBACK
		--------------------------------------------------

		if not desired_flash then
			desired_flash = "MuzzleEffect"
		end

		-- HARD FAIL SAFE
		if not desired_flash then
			warn("muzzleflash called with nil type, defaulting to MuzzleEffect")
			desired_flash = "MuzzleEffect"
		end

		local flashFolder = repeffects:FindFirstChild("flash_effects")
		if not flashFolder then return end

		local template = flashFolder:FindFirstChild(desired_flash)
		if not template then
			warn("Missing muzzle effect:", desired_flash)
			return
		end

		-- clone attachment
		local flash = template:Clone()
		if flash:IsA("Attachment") then
			flash.Parent = barrel
		else
			flash.CFrame = barrel.CFrame
			flash.Parent = workspace.Ignore
		end

		--------------------------------------------------
		-- PARTICLE EMISSION
		--------------------------------------------------

		for _, obj in ipairs(flash:GetDescendants()) do
			if obj:IsA("ParticleEmitter") then

				local emitCount = obj:GetAttribute("EmitCount")

				if emitCount then
					-- BURST EMITTER (controlled)
					obj:Emit(emitCount)
				else
					-- CONTINUOUS EMITTER (let it run briefly)
					obj.Enabled = true
				end
			end
		end

		-- let particles actually breathe
		task.delay(0.12, function()
			for _, obj in ipairs(flash:GetDescendants()) do
				if obj:IsA("ParticleEmitter") then
					obj.Enabled = false
				end
			end
		end)

		--------------------------------------------------
		-- MUZZLE LIGHT
		--------------------------------------------------

		local light = flash:FindFirstChild("MuzzleLight")
		if light and light:IsA("SpotLight") then
			light.Enabled = true
			light.Brightness = light.Brightness * (0.9 + math.random() * 0.2)

			task.spawn(function()
				-- VERY fast flicker like irl muzzle flash's
				task.wait(0.02)
				light.Enabled = false
			end)
		end

		--------------------------------------------------
		-- RANDOM ROTATION
		--------------------------------------------------

		flash.Orientation = Vector3.new(
			math.random(-2,2),
			math.random(-2,2),
			math.random(-2,2)
		)

		--------------------------------------------------
		-- CLEANUP
		--------------------------------------------------

		game.Debris:AddItem(flash, 0.5)

		--------------------------------------------------
		-- HEAT-BASED BARREL SMOKE
		--------------------------------------------------

		local partik = barrel:FindFirstChild("BarrelSmoke")

		if not partik then
			partik = barrelsmoke:Clone()
			partik.Name = "BarrelSmoke"
			partik.Parent = barrel

			partik:SetAttribute("Heat", 0)

			task.spawn(function()
				while partik and partik.Parent do
					local heat = partik:GetAttribute("Heat") or 0
					heat = heat * 0.92

					if heat < 0.05 then
						heat = 0
					end

					partik:SetAttribute("Heat", heat)
					partik.Enabled = heat > 0
					partik.Rate = (heat ^ 1.2) * 2

					task.wait(0.1)
				end
			end)
		end

		local currentHeat = partik:GetAttribute("Heat") or 0
		partik:SetAttribute("Heat", math.clamp(currentHeat + 2.5, 0, 50))

		--------------------------------------------------
		-- CAMERA LIGHT KICK
		--------------------------------------------------

		if char and char.firemuzzlelight then
			char:firemuzzlelight()
		end

	end -- NICE


