			local FragShuffleBag = {}
			local FragLastPlayed = nil

			local function FragReshuffle()
				FragShuffleBag = {}

				for i = 1, #FragSoundIds do
					table.insert(FragShuffleBag, FragSoundIds[i])
				end

				for i = #FragShuffleBag, 2, -1 do
					local j = math.random(1, i)
					FragShuffleBag[i], FragShuffleBag[j] = FragShuffleBag[j], FragShuffleBag[i]
				end

				if FragLastPlayed and FragShuffleBag[1] == FragLastPlayed then
					local swapIndex = math.random(2, #FragShuffleBag)
					FragShuffleBag[1], FragShuffleBag[swapIndex] = FragShuffleBag[swapIndex], FragShuffleBag[1]
				end
