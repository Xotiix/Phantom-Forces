		-- === SMOOTH FOV SENS SCALING ===
		local targetScale = atan(tan(camera.basefov * deg / 2) / e^camera.magspring.p)
		camera.smoothedFOVScale = camera.smoothedFOVScale + (targetScale - camera.smoothedFOVScale) * math.clamp(dt * 10, 0, 1)
		if char.aimbotstep then char.aimbotstep() end
		accelspring.t=char.acceleration
		if camera.type=="firstperson" then
