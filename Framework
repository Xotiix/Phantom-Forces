			end
			local function explode()
				exploded=true
				trash.remove(flyingnade)
				dunhit={}
				if data.grenadetype=="Frag" then
					---need to add network stuff later
					if #FragShuffleBag == 0 then
						FragReshuffle()
					end

					local nextSound = table.remove(FragShuffleBag, 1)
					FragLastPlayed = nextSound
					self.lastSound = nextSound or FragSoundIds[1]

					-- MAIN EXPLOSION (close, punchy)
					play3DSound(
						nextSound,
						position,
						3.2 + math.random() * 0.6,
						15,
						220,
						math.random(98,102)/100
					)

					-- BASS SHOCKWAVE (low-end hit)
					task.delay(0.03, function()
						play3DSound(
							"rbxassetid://129147959035010",
							position,
							4,
							20,
							180,
							0.85
						)
					end)

					-- DISTANT TAIL (echo / battlefield feel)
					task.delay(0.12, function()
						play3DSound(
							"rbxassetid://100651384867178", -- distant boom
							position,
							2,
							80,
							600,
							math.random(90,100)/100
						)
					end)
					local boom=new("Explosion",workspace)
					boom.Position=position
					boom.BlastRadius=blastradius
					boom.BlastPressure=0
					boom.DestroyJointRadiusPercent=0
					boom.Hit:connect(function(hit,dist)
