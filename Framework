		local prof  = recoilProfiles[wtype] or recoilProfiles.default

		-- alternate horizontal bias
		camera.rollBias = -camera.rollBias

		local vert  = strength * prof.vert
		local horiz = strength * prof.horiz * camera.rollBias
		local roll  = horiz * prof.roll

