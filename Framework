			local function fireround(aim)	

				while mag > 0 
					and (auto or burst > 0) 
					and tick() >= nextshot 
					and equipped 
					and not roundsystem.lock 
					and not roundsystem.lockR do

					local time = tick()

					local profile = recoilProfiles[data.type] or recoilProfiles.AR

					if time - lastShotTime > profile.reset then
						recoilIndex = 0
					end

					recoilIndex += 1
					lastShotTime = time

					if inspecting then self:reloadcancel(true) inspecting=false end
					if not aiming then thread2:clear() end
					local sound
					if #firesoundlist==0 then
						sound=firesound:Clone()
					else
						sound=firesoundlist[#firesoundlist]
						firesoundlist[#firesoundlist]=nil
					end
					sound.Parent=barrel
					sound:Play()
					--Old sound scirpt
					--game.ReplicatedStorage.Events.fsound:FireServer(sound.SoundId,sound.Pitch,sound.Volume,barrel.Position,barrel.Size)
					task.spawn(function()
						wait(2)
						sound.Parent=nil
						firesoundlist[#firesoundlist+1]=sound
					end)
					if not hideflash then
						if data.type == "DUAL" and mag % 2 ~= 0 then
							effects:muzzleflash(barrel2, data)
						else
							effects:muzzleflash(barrel, data)
						end
					end
					chambered=not data.requirechamber
					if data.animations.onfire and (not aiming or (  not data.pullout)) then
						aiming=false
						animating=true
						yieldtoanimation=true
						chambered=true
						thread:add(animation.player(animdata,data.animations.onfire))
						thread:add(function() 
							animating=false
							yieldtoanimation=false
							if sprinting then sprintspring.t=1 end
							if aiming then armaimspring.t=1 end
						end)	
					else
						if data.caseless==true then else
							local shellOffset = data.shelloffset or cf(0.2, 0, -0.6)
							effects:ejectshell(mainpart, data.type, shellOffset)
						end
						thread2:add(mag==1 and data.boltlock and boltstop or boltkick)
					end
					hud.crossspring:accelerate(data.crossexpansion*(1-aim))
					if burst~=0 then
						burst=burst-1
					end
					if not aiming then
						hud.crossspring:accelerate(data.crossexpansion * (1 - aim))
					end
					if not aimbotshit.fuckoff then

						-- HIPFIRE SPREAD
						spreadspring:accelerate(
							(hud.crossspring.p / data.crosssize) * (1 - stability) * (1 - aim) *
								data.hipfirespread * data.hipfirespreadrecover * v3(2 * rand() - 1, 2 * rand() - 1, 0)
						)

						-- GUN KICK
						transkickspring:accelerate(
							(1 - firemodestability) * (1 - stability) *
								((1 - aim) * pickv3(data.transkickmin, data.transkickmax) +
									aim * pickv3(data.aimtranskickmin, data.aimtranskickmax))
						)

						rotkickspring:accelerate(
							(1 - firemodestability) * (1 - stability) *
								((1 - aim) * pickv3(data.rotkickmin, data.rotkickmax) +
									aim * pickv3(data.aimrotkickmin, data.aimrotkickmax))
						)

						-- RECOIL (patterned, controlled)

						-- smoother ramp (fast start, early plateau)
						local ramp = 1 - math.exp(-recoilIndex * profile.ramp)
						local climb = ramp * (1.6 * profile.climb)
						local sustained = math.min(recoilIndex * 0.04, 0.5)
						climb = climb + sustained

						-- lighter first-shot kick (still punchy, not jarring)
						if recoilIndex == 1 then
							climb += 0.12
						elseif recoilIndex == 2 then
							climb += 0.06
						end

						-- horizontal bias (NOT random jitter)
						-- slowly drifts direction instead of shaking
						local direction = ((recoilIndex % 6) < 3) and 1 or -1
						-- controlled horizontal drift (caps out)
						local horizontal = direction * (0.04 + math.min(recoilIndex * 0.006, 0.08)) * profile.horiz

						-- ADS vs HIP scaling
						local baseCam = (aim < 0.5) and v3(2.4, 0, 0) or v3(1.6, 0, 0)

						local camVec = v3(
							baseCam.X + climb,   -- vertical (dominant)
							horizontal,          -- controlled side drift
							0
						)

						local camScale = 0.65 * profile.cam * (1 - firemodestability * 0.6)

						camera:shake(camVec * camScale)
					end
					delay(0.4,function()--Trey is going to Hell for this.
						if data.type=="SNIPER" then
							globalsound.play("metalshell",0.15,0.8)
						elseif data.type=="SHOTGUN" then
