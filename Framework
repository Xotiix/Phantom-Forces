			local len=0
			local i=1
			while data[i] do
				local str=write(data[i])..";"
				n=n+1;string[n]=str
				len=len+#str
				i=i+1
			end
			for k,v in next,data do
				if type(k)~="number" or i<k or k%1~=0 then
