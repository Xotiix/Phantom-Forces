utility = utility or {}

do
	--------------------------------------------------------
	-- FAST LOCALS
	--------------------------------------------------------
	local clock = os.clock
	local new = Instance.new

	--------------------------------------------------------
	-- array → hash
	--------------------------------------------------------
	function utility.arraytohash(array, hashfunc)
		local newtable = {}
		for i = 1, #array do
			local v = array[i]
			newtable[hashfunc(v)] = v
		end
		return newtable
	end

	--------------------------------------------------------
	-- safe waitfor (timeout protected)
	--------------------------------------------------------
	function utility.waitfor(object, timeout, ...)
		local indices = { ... }
		local current = object
		local quit = clock() + (timeout or 10)

		for i = 1, #indices do
			if not current then
				return
			end

			if typeof(current) == "Instance" then
				local remaining = math.max(0, quit - clock())
				current = current:WaitForChild(indices[i], remaining)
			else
				repeat
					task.wait()
					current = current[indices[i]]
				until current or clock() > quit
			end

			if clock() > quit then
				return
			end
		end

		return current
	end

	--------------------------------------------------------
	-- get descendants (manual, non-recursive)
	--------------------------------------------------------
	function utility.getdescendants(object, class)
		class = class or "Instance"

		local stack = object:GetChildren()
		local i = 0

		while i < #stack do
			i += 1
			local children = stack[i]:GetChildren()
			for j = 1, #children do
				stack[#stack + 1] = children[j]
			end
		end

		local result = {}
		for i = 1, #stack do
			if stack[i]:IsA(class) then
				result[#result + 1] = stack[i]
			end
		end

		return result
	end

	--------------------------------------------------------
	-- weld (replication-safe Motor6D)
	--------------------------------------------------------
	function utility.weld(part0, part1, c0)
		c0 = c0 or part0.CFrame:ToObjectSpace(part1.CFrame)

		local weld = new("Motor6D")
		weld.Part0 = part0
		weld.Part1 = part1
		weld.C0 = c0
		weld.Parent = part0

		part0.Anchored = false
		part1.Anchored = false

		return weld
	end

	--------------------------------------------------------
	-- remove values from array (stable)
	--------------------------------------------------------
	function utility.removevalue(array, removals)
		local removemap = {}
		for i = 1, #removals do
			removemap[removals[i]] = true
		end

		local write = 1
		for read = 1, #array do
			local v = array[read]
			if not removemap[v] then
				array[write] = v
				write += 1
			end
		end

		for i = write, #array do
			array[i] = nil
		end

		return array
	end
