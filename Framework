do
	local pi      = math.pi
	local cos     = math.cos
	local sin     = math.sin
	local acos    = math.acos
	local asin    = math.asin
	local atan2   = math.atan2
	local random  = math.random
	local sqrt    = math.sqrt
	local v3      = Vector3.new

	-- immutable zero vector (do NOT mutate)
	local ZERO = v3(0,0,0)

	vector.identity = ZERO
	vector.new      = v3
	vector.lerp     = ZERO.Lerp
	vector.cross    = ZERO.Cross
	vector.dot      = ZERO.Dot

	------------------------------------------------------------
	-- SAFETY HELPERS
	------------------------------------------------------------

	local function magsq(x,y,z)
		return x*x + y*y + z*z
	end

	function vector.magnitude(v)
		return sqrt(v.x*v.x + v.y*v.y + v.z*v.z)
	end

	function vector.magnitudesq(v)
		return v.x*v.x + v.y*v.y + v.z*v.z
	end

	function vector.safeunit(v)
		local x,y,z = v.x,v.y,v.z
		local m = x*x + y*y + z*z
		if m > 1e-8 then
			m = 1 / sqrt(m)
			return v3(x*m, y*m, z*m)
		end
		return ZERO
	end

	function vector.iszero(v)
		return v.x == 0 and v.y == 0 and v.z == 0
	end

	------------------------------------------------------------
	-- RANDOM VECTORS
	------------------------------------------------------------

	function vector.random(a,b)
		-- uniform random direction
		local p = acos(1 - 2 * random()) / 3
		local z = sqrt(3) * sin(p) - cos(p)
		local r = sqrt((1 - z*z) * random())
		local t = 2*pi * random()
		local x = r * cos(t)
		local y = r * sin(t)

		if b then
			local m = (a + (b - a) * random()) / sqrt(x*x + y*y + z*z)
			return v3(m*x, m*y, m*z)
		elseif a then
			return v3(a*x, a*y, a*z)
		else
			return v3(x,y,z)
		end
	end

	------------------------------------------------------------
	-- ANGLE CONVERSIONS (YX)
	------------------------------------------------------------

	function vector.anglesyx(x,y)
		local cx = cos(x)
		return v3(
			-cx * sin(y),
			sin(x),
			-cx * cos(y)
		)
	end

	function vector.toanglesyx(v)
		local x,y,z = v.x,v.y,v.z
		local m = sqrt(x*x + y*y + z*z)
		if m < 1e-8 then
			return 0,0
		end
		return asin(y/m), atan2(-x, -z)
	end

	------------------------------------------------------------
	-- SPHERICAL LERP (SAFE)
	------------------------------------------------------------

	function vector.slerp(v0, v1, t)
		local x0,y0,z0 = v0.x,v0.y,v0.z
		local x1,y1,z1 = v1.x,v1.y,v1.z

		local m0 = sqrt(x0*x0 + y0*y0 + z0*z0)
		local m1 = sqrt(x1*x1 + y1*y1 + z1*z1)

		if m0 < 1e-8 or m1 < 1e-8 then
			return vector.lerp(v0, v1, t)
		end

		local co = (x0*x1 + y0*y1 + z0*z1) / (m0 * m1)

		if co < -0.99999 then
			-- opposite vectors
			local ax = math.abs(tonumber(x0))
			local ay = math.abs(tonumber(y0))
			local az = math.abs(tonumber(z0))

			local px,py,pz = 0,0,0
			if ax < ay then
				if ax < az then px = 1 else pz = 1 end
			else
				if ay < az then py = 1 else pz = 1 end
			end

			local th = acos((x0*px + y0*py + z0*pz) / m0)
			local r  = pi/th * t
			local s  = ((1-t)*m0 + t*m1) / sin(th)

			local s0 = s/m0 * sin((1-r)*th)
			local s1 = s/m1 * sin(r*th)

			return v3(
				s0*x0 + s1*px,
				s0*y0 + s1*py,
				s0*z0 + s1*pz
			)

		elseif co < 0.99999 then
			local th = acos(co)
			local s  = ((1-t)*m0 + t*m1) / sqrt(1 - co*co)
			local s0 = s/m0 * sin((1-t)*th)
			local s1 = s/m1 * sin(t*th)

			return v3(
				s0*x0 + s1*x1,
				s0*y0 + s1*y1,
				s0*z0 + s1*z1
			)
		else
			-- almost parallel
			return vector.lerp(v0, v1, t)
		end
	end

	------------------------------------------------------------
	-- MODERN HELPERS (OPTION B)
	------------------------------------------------------------

	function vector.reflect(dir, normal)
		-- reflect dir around normal
		local d = dir:Dot(normal)
		return dir - 2*d*normal
	end

	function vector.projectOnPlane(v, normal)
		return v - normal * v:Dot(normal)
	end

	function vector.flatten(v)
		return v3(v.x, 0, v.z)
	end

	function vector.clampMagnitude(v, maxLen)
		local m = v.x*v.x + v.y*v.y + v.z*v.z
		if m > maxLen*maxLen then
			return vector.safeunit(v) * maxLen
		end
		return v
	end

	function vector.spread(dir, angle)
		-- deterministic cone spread around direction
		if angle <= 0 then return dir end
		local u = vector.safeunit(dir)
		local r = vector.random()
		local t = random() * angle
		return vector.safeunit(
			u*cos(t) + vector.safeunit(r:Cross(u))*sin(t)
		)
	end
end



















