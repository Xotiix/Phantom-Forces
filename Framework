		do -- cac weapon rotation recode
			local UIS = game:GetService("UserInputService")
			local RunService = game:GetService("RunService")

			local rotating = false
			local lastPos = Vector2.zero

			-- rotation targets
			local rotX = 0
			local rotY = 0

			-- smoothed output
			local smoothX = 0
			local smoothY = 0

			-- inertia velocity
			local velX = 0
			local velY = 0

			-- idle tracking
			local idleTime = 0
			local returnDelay = 2 -- time before it starts returning
			local returnSpeed = 1.8 -- how fast it recenters

			-- tuning
			local baseSensitivity = 0.0055
			local accel = 28
			local damping = 0.82
			local maxVel = 6

			UIS.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton2 then
					rotating = true
					lastPos = UIS:GetMouseLocation()
					idleTime = 0
				end
			end)

			UIS.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton2 then
					rotating = false
				end
			end)

			UIS.InputChanged:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseWheel then
					camera:changemenufov(input.Position.Z * 0.4)
				end
			end)

			RunService.RenderStepped:Connect(function(dt)
				if not (curgun and curgun.PrimaryPart) then return end

				-- camera sync
				local sensitivity = baseSensitivity * (camera.smoothedFOVScale or 1)

				if rotating then
					idleTime = 0

					local mousePos = UIS:GetMouseLocation()
					local delta = mousePos - lastPos
					lastPos = mousePos

					rotX = rotX - delta.Y * sensitivity
					rotY = rotY - delta.X * sensitivity

					rotX = math.clamp(rotX, -math.rad(45), math.rad(45))
					rotY = math.clamp(rotY, -math.rad(180), math.rad(180))
				else
					idleTime += dt

					-- gun center wen left idle
					if idleTime > returnDelay then
						local t = math.clamp((idleTime - returnDelay) * returnSpeed, 0, 1)

						-- smoothly pulls it back to 0
						rotX = rotX * (1 - t)
						rotY = rotY * (1 - t)
					end
				end

				-- inertia baby
				local targetVelX = (rotX - smoothX) * accel
				local targetVelY = (rotY - smoothY) * accel

				velX = velX + (targetVelX - velX) * math.clamp(dt * 10, 0, 1)
				velY = velY + (targetVelY - velY) * math.clamp(dt * 10, 0, 1)

				velX *= damping
				velY *= damping

				velX = math.clamp(velX, -maxVel, maxVel)
				velY = math.clamp(velY, -maxVel, maxVel)

				smoothX = smoothX + velX * dt
				smoothY = smoothY + velY * dt

				local baseCF = CFrame.new(stand.Position + Vector3.new(0, 3, 0))

				local rotation =
					CFrame.Angles(0, smoothY, 0) *
					CFrame.Angles(smoothX, 0, 0)

				curgun:SetPrimaryPartCFrame(baseCF * rotation)
			end)
		end

