					if hit then

						position = pos + norm * 0.01

						local normalVel = norm * dot(velocity, norm)
						local tangentVel = velocity - normalVel

						-- MW grenades lose a lot of vertical energy
						local bounce = -normalVel * bounceelasticity

						-- surface friction
						local friction = 0.65
						tangentVel = tangentVel * friction

						velocity = bounce + tangentVel

						-- stop tiny bounces (start rolling instead)
						if velocity.Magnitude < 3 then
							velocity = tangentVel * 0.4
						end

						-- spin impulse
						av0 = norm:Cross(velocity) * 4
						rot0 = flyingnade.CFrame - flyingnade.CFrame.p
