					end)
				elseif data.grenadetype=="Smoke" then
					play3DSound(
						"rbxassetid://13482378074",
						position,
						2.5,
						10,
						120,
						math.random(98,102)/100
					)
					local boom = game.ReplicatedStorage.Effects.SmokePart:Clone()
					boom.Parent = workspace
					boom.Position = position

					-- 🔥 CONTINUOUS SMOKE EFFECT (REAL FIX)
					task.spawn(function()
						local duration = data.time
						local start = tick()

						while tick() - start < duration do
							for _, playerObj in pairs(game.Players:GetPlayers()) do
								local char = playerObj.Character
								if char and char:FindFirstChild("HumanoidRootPart") then
									local dist = (char.HumanoidRootPart.Position - position).Magnitude

									if dist < data.blastradius then -- smoke radius
										Smokeplayer(char, dist)
									end
								end
							end
							task.wait(0.3)
						end
					end)

					-- cleanup
					task.delay(data.time, function()
						if boom then boom:Destroy() end
					end)
					--- smoke
				elseif data.grenadetype=="Flash" then
					play3DSound(
						"rbxassetid://14696426287",
						position,
						2.2,
						8,
						90,
						math.random(100,105)/100
					)
					local boom = game.ReplicatedStorage.Effects:FindFirstChild("FlashPart"):Clone()
					boom.Parent = workspace.Ignore
					boom.Position = position

					-- 🔥 DETECT PLAYERS MANUALLY
					task.spawn(function()
						local start = tick()

						while tick() - start < 0.25 do
							for _, playerObj in pairs(game.Players:GetPlayers()) do
								local char = playerObj.Character
								if char and char:FindFirstChild("Head") then
									local dist = (char.Head.Position - position).Magnitude
									blindplayer(char, dist)
								end
							end
							task.wait()
						end
					end)

					-- cleanup
					task.delay(0.25, function()
						if boom then boom:Destroy() end
					end)
				elseif data.grenadetype=="Flare" then
					--- signal
				elseif data.grenadetype=="Throwing" then
					--- flying knives wat
				end
			end



			local stepConnection
			stepConnection = run.onstep:connect(function(dt)
				thread2.step()
				local time=tick()

				--cooking stuff
				if cooking and not throwing then
					if cooktime<time or not input.keyboard.down["g"] then
						self:throw()
					elseif (cooktime-time)%1<0.03 then
						hud.crossspring:accelerate(data.crossexpansion)
					end
				end				

				--grenade throwing physics
				if flyingnade and not exploded then
					if time<blowup then
						local newvelocity=velocity+dt*acceleration
						local newposition=position+dt*velocity
						local hit,pos,norm=raycast(workspace,ray(position,newposition-position),ignorelist)
						local hitCheck = raycast(workspace, ray(position, (camera.cframe.p - position)), ignorelist)

						indicator.Enabled = (hitCheck == nil)

						if hit and hit.Name ~= "Window" then

							position = pos + norm * 0.01

							-- split velocity
							local normalVel = norm * dot(velocity, norm)
							local tangentVel = velocity - normalVel

							-- 🔥 HEAVY MW-STYLE BOUNCE (kills vertical energy hard)
							local bounce = -normalVel * 0.25   -- was bounceelasticity (too bouncy)

							-- 🔥 SURFACE FRICTION (MW grenades lose speed fast)
							local material = hit.Material

							local frictionMap = {
								[Enum.Material.Concrete] = 0.55,
								[Enum.Material.Metal] = 0.65,
								[Enum.Material.Grass] = 0.45,
								[Enum.Material.Sand] = 0.35,
								[Enum.Material.Wood] = 0.5
							}

							local friction = frictionMap[material] or 0.6
							tangentVel = tangentVel * friction

							velocity = bounce + tangentVel

							-- 🔥 STOP MICRO BOUNCING → START ROLLING
							if velocity.Magnitude < 4 then
								velocity = tangentVel * 0.35
							end

							-- 🔥 SPIN IMPULSE (less chaotic than PF)
							av0 = norm:Cross(velocity) * 3

							-- MW grenades stop spinning over time
							av0 = av0 * 0.95

							rot0 = flyingnade.CFrame - flyingnade.CFrame.p
							t0 = tick()

							lastbounce = true
						else
							position=newposition
							velocity=newvelocity
							lastbounce=false
							if hit and hit.Name=="Window" then
								effects:breakwindow(hit,pos,norm,velocity)
							end
						end
						-- TRAIL
						local dist = (lasttrailpos - position).Magnitude

						if lasttrailt + 0.035 < time and dist > 0.25 then

							local trail = new("Part")
							trail.Parent = workspace.Ignore
							trail.Anchored = true
							trail.CanCollide = false
							trail.Transparency = 1
							trail.Size = v3(0.2,0.2,0.2)

							trail.CFrame = cf((lasttrailpos + position) * 0.5, position)

							local mesh = new("BlockMesh")
							mesh.Parent = trail
							mesh.Scale = v3(
								0.35,
								0.35,
								dist * 3
							)

							debris:AddItem(trail, 0.25)

							lasttrailpos = position
							lasttrailt = time
						end
						flyingnade.CFrame = cf(position + offset) * cframe.fromaxisangle((time - t0) * av0) * rot0
					else
						explode()
						if typeof(stepConnection) == "RBXScriptConnection" then
							stepConnection:Disconnect()
						end
					end
				end

			end)

			function self.step()
				--Animate grenade arms
				local mainweldc0=rootpart.CFrame:inverse()
					*camera.shakecframe
					*mainoffset*animdata[main].weld.C0
					--*breathing()
					*pronecf(pronespring.p)
					--*cf(-velocityspring.v/8192)
					*cf(0,0,1)*cframe.fromaxisangle(swingspring.v)*cf(0,0,-1)
					*gunbob(0.7,1)
					*gunsway(0)
					*cframe.interpolate(sprintcf(truespeedspring.p/walkspeedspring.p*sprintspring.p),data.equipoffset,equipspring.p)
				mainweld.C0=mainweldc0
				--Animate arms
				lweld.C0=mainweldc0*animdata.larm.weld.C0
				rweld.C0=mainweldc0*animdata.rarm.weld.C0
				if char.health<=0 then
					if typeof(stepConnection) == "RBXScriptConnection" then
						stepConnection:Disconnect()
					end
					self:setequipped(false)
				end
			end

			return self
		end		
