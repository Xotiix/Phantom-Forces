	function effects:bullethit(hit,pos,norm,smokeon,holeon,sparkson)

		--------------------------------------------------
		-- SPARKS
		--------------------------------------------------

		if sparkson and hit.Material ~= Enum.Material.Sand
			and hit.Material ~= Enum.Material.Grass
			and hit.Material ~= Enum.Material.Wood then

			local sparkCount = 2 * sparkson

			if hit.Material == Enum.Material.Metal then
				sparkCount = sparkCount * 2
			end

			for i=1,sparkCount do
				particle.new{
					position = pos;

					velocity =
						norm*random(30,60) +
						vector.random(25);

					acceleration = v3(0,-196.2,0);

					cancollide = false;
					size = 0.1;

					brightness = 10 + 15*random();

					color = Color3.new(
						1,
						0.7 + math.random()*0.2,
						0.5 + math.random()*0.2
					);

					bloom = 0.004 + random()*0.006;

					life = 0.2 + random()*0.2
				}
			end
		end


		--------------------------------------------------
		-- SHOOTING LIGHTS
		--------------------------------------------------

		if (hit.Name=="light" or hit.Name=="Light") then
			if ffc(hit,"SpotLight") then
				hit.SpotLight:Destroy()
			end

			hit.Material = Enum.Material.SmoothPlastic

			for i=1,20 do
				particle.new{
					position = pos;

					velocity =
						norm*30 +
						vector.random(15);

					acceleration = v3(0,-20,0);

					cancollide=false;
					size=0.1;

					brightness=20*random();
					color=Color3.new(1,1,0.8);

					bloom=0.005*random();
					life=10
				}
			end
		end


		--------------------------------------------------
		-- SMOKE / DUST
		--------------------------------------------------

		if smokeon then

			local smokepart

			if #smokelist ~= 0 then
				smokepart = smokelist[#smokelist]
				smokelist[#smokelist] = nil
			else
				smokepart = smoke:Clone()
			end

			smokepart:BreakJoints()

			smokepart.CFrame =
				cf(pos,pos+norm+v3(random()-0.5,random()-0.5,random()-0.5)) *
				angles(-90*deg,random(0,360)*deg,0)

			local c1,c2

			if hit.Material == Enum.Material.Grass then
				c1 = color(0.47,0.56,0.50)
				c2 = color(20/255,157/255,30/255)

			elseif hit.Material == Enum.Material.Sand then
				c1 = color(225/255,210/255,149/255)
				c2 = color(216/255,205/255,159/255)

			elseif hit.Material == Enum.Material.Wood then
				c1 = color(101/255,67/255,33/255)
				c2 = color(140/255,90/255,40/255)

			elseif hit.Material == Enum.Material.Metal then
				c1 = color(0.6,0.6,0.6)
				c2 = color(0.4,0.4,0.4)

			else
				c1 = color(145/255,143/255,145/255)
				c2 = color(141/255,140/255,140/255)
			end

			local seq = colorseq(c1,c2)

			smokepart.Smoke.Color = seq
			smokepart.Smoke2.Color = seq

			smokepart.Smoke.Enabled = true
			smokepart.Smoke2.Enabled = true
			smokepart.Dust.Enabled = true

			smokepart.Parent = ignore

			-- outward burst
			smokepart.Dust.Acceleration =
				norm*random(3,6) +
				v3(random()-0.5,-1,random()-0.5)

			task.delay(0.08,function()

				smokepart.Smoke.Enabled = false
				smokepart.Smoke2.Enabled = false
				smokepart.Dust.Enabled = false

				task.delay(3,function()

					smokepart.Parent=nil
					smokelist[#smokelist+1]=smokepart

				end)

			end)

		end


		--------------------------------------------------
		-- BULLET HOLES
		--------------------------------------------------

		if holeon and hit.Transparency==0 and hit.CanCollide then

			local holepart

			if #holelist ~= 0 then
				holepart = holelist[#holelist]
				holelist[#holelist] = nil
			else
				holepart = hole:Clone()
			end

			holepart:BreakJoints()
			holepart.Parent = ignore

			holepart.CFrame =
				cf(pos,pos-norm) *
				angles(-90*deg,random(0,360)*deg,0)

			local materials = materiallist[Enum.Material.Cobblestone]

			if materiallist[hit.Material] then
				materials = materiallist[hit.Material]
			end

			local randId =
				"http://www.roblox.com/asset/?id="..
				materials[random(1,#materials)]

			holepart.Decal1.Texture = randId
			holepart.Decal2.Texture = randId

			task.delay(4,function()
				holepart.Parent=nil
				holelist[#holelist+1]=holepart
			end)

		end
	end

	--// WINDOW RUN-THROUGH SYSTEM

	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")

	local player = Players.LocalPlayer

	local SPEED_THRESHOLD = 20
	local BREAK_COOLDOWN = 0.15

	local lastBreak = 0

	RunService.RenderStepped:Connect(function()
		local char = player.Character
		if not char then return end

		local root = char:FindFirstChild("HumanoidRootPart")
		if not root then return end

		local velocity = root.Velocity.Magnitude
		if velocity < SPEED_THRESHOLD then return end

		local ignoreList = {char}

		local direction = root.CFrame.LookVector * 4
		local params = RaycastParams.new()
		params.FilterType = Enum.RaycastFilterType.Exclude
		params.FilterDescendantsInstances = ignoreList

		local result = workspace:Raycast(root.Position, direction, params)

		if result and result.Instance and result.Instance.Name == "Window" then
			if tick() - lastBreak > BREAK_COOLDOWN then
