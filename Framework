		local function bindSlider(sliderFrame, minValue, maxValue, getValue, setValue, onChange)
			local dragging = false

			local bar = sliderFrame:WaitForChild("Bar") -- fill frame
			local knob = sliderFrame:WaitForChild("Knob") -- draggable circle/button

			local function updateFromX(x)
				local absPos = sliderFrame.AbsolutePosition.X
				local absSize = sliderFrame.AbsoluteSize.X

				local alpha = math.clamp((x - absPos) / absSize, 0, 1)

				local value = minValue + (maxValue - minValue) * alpha

				knob.Position = UDim2.new(alpha, -knob.AbsoluteSize.X/2, 0.5, -knob.AbsoluteSize.Y/2)
				bar.Size = UDim2.new(alpha, 0, 1, 0)

				setValue(value)
				if onChange then onChange(value) end
			end

			-- initialize position
			do
				local raw = getValue()

				-- convert string presets if needed
				if typeof(raw) ~= "number" then
					raw = tonumber(raw) or minValue
				end

				local v = math.clamp(raw, minValue, maxValue)
				local alpha = (v - minValue) / (maxValue - minValue)
				alpha = math.clamp(alpha, 0, 1)

				knob.Position = UDim2.new(alpha, -knob.AbsoluteSize.X/2, 0.5, -knob.AbsoluteSize.Y/2)
				bar.Size = UDim2.new(alpha, 0, 1, 0)
			end

			knob.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
				end
			end)

			UIS.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
				end
			end)

			UIS.InputChanged:Connect(function(input)
				if not dragging then return end
				if input.UserInputType == Enum.UserInputType.MouseMovement then
					updateFromX(input.Position.X)
				end
			end)

			sliderFrame.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					updateFromX(input.Position.X)
					dragging = true
				end
			end)
		end

