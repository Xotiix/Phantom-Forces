			local function hitdetection(hit,dist) --- frag damage
				---damage code
				local character = hit.Parent
				local playerObj = character and game.Players:GetPlayerFromCharacter(character)

				if playerObj and not dunhit[character] then
					local p=game.Players:GetPlayerFromCharacter(hit.Parent)
					if p.TeamColor~=player.TeamColor or p==player then
						local wall,pos=raycast(workspace,ray(hit.Position,(hit.Position-position).unit*-dist),ignorelist)
						if not wall then
							effects:bloodhit(position,hit,hit.Position,hit.CFrame.lookVector)
							local damage=dist<r0 and d0 or dist<r1 and (d1-d0)/(r1-r0)*(dist-r0)+d0 or d1
							--print("damage : " ..damage.. "  dist : " ..dist.. "   wall : ",wall)
							network:send('c'..'h'..'a'..'n'..'g'..'e'..'h'..'e'..'a'..'l'..'t'..'h'..'x',p,player,tick(),-damage,player,data.name,hit,position)
							hud:changehealthlocally(player,-damage)
							dunhit[hit.Parent]=true
							hud:firehitmarker(hit.Name)
						end
					end


				elseif hit.Name == "HitBoxBoom" then
					local damage=data.damage1

					local prop = hit.Parent.PropHealth 
					prop.Health = prop.Health - damage
					dunhit[hit.Parent]=true
					hud:firehitmarker()
					if prop.Health <= 0 then
						network:send('b'..'o'..'o'..'m'..'D'..'L'..'C',hit)
					end
				elseif hit.Name == "HitBoxNPC" then
					local damage=data.damage1

					local prop = hit.Parent.PropHealth 

					dunhit[hit.Parent]=true
					hud:firehitmarker()
					if prop.Health <= 0 then
						network:send('P'..'r'..'o'..'p'..'H'..'e'..'a'..'l'..'t'..'h',hit,damage,player)
					end
				end
			end

			local function blindplayer(character, dist)
				local p = game.Players:GetPlayerFromCharacter(character)
				if not p or dunhit[character] then return end

				local head = character:FindFirstChild("Head")
				if not head then return end

				if dist > 60 then return end

				local dir = (head.Position - position)
				local wall = raycast(workspace, ray(position, dir), ignorelist)
				if wall then return end

				local look = head.CFrame.LookVector
				local toFlash = (position - head.Position).Unit
				local dotProd = look:Dot(toFlash)

				if dotProd < 0.35 then return end

				-- 🔥 APPLY GUI INSTEAD OF HUD
				local playerGui = p:FindFirstChild("PlayerGui")
				if playerGui and not playerGui:FindFirstChild("Blindness") then
					local effect = game.ReplicatedStorage.Effects:FindFirstChild("Blindness"):Clone()
					effect.Parent = playerGui

					-- 🔥 AUTO CLEANUP (MW-style base)
					task.delay(4, function()
						if effect and effect.Parent then
							effect:Destroy()
						end
					end)
				end

				dunhit[character] = true
			end


