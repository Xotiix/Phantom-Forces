	local TweenService = game:GetService("TweenService")

	----------------------------------------------------
	-- SAFE UDim2 SCALE HELPER
	----------------------------------------------------

	local function scaleUDim2(size, factor)
		return UDim2.new(
			size.X.Scale * factor,
			size.X.Offset * factor,
			size.Y.Scale * factor,
			size.Y.Offset * factor
		)
	end

	----------------------------------------------------
	-- MW2019 POPUP STACK SYSTEM
	----------------------------------------------------

	local popupStack = {}
	local popupSpacing = 20 -- pixels between popups
	local baseY = 0      -- bottom offset anchor
	local maxPopups = 5

	local function restackPopups()
		for i, frame in ipairs(popupStack) do
			if frame and frame.Parent then
				local yOffset = baseY - ((i - 1) * popupSpacing)

				-- ONLY tween if NOT currently entering
				if not frame:GetAttribute("Entering") then
					TweenService:Create(
						frame,
						TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
						{
							Position = ud2(0.5, 0, 1, yOffset)
						}
					):Play()
				end
			end
		end
	end

	local function pushPopup(frame)
		table.insert(popupStack, frame)

		if #popupStack > maxPopups then
			local oldest = table.remove(popupStack, 1)
			if oldest then
				oldest:Destroy()
			end
		end

		restackPopups()
	end

	local function removePopup(frame)
		for i = #popupStack, 1, -1 do
			if popupStack[i] == frame then
				table.remove(popupStack, i)
				break
			end
		end
		restackPopups()
	end

	local function getStackY(frame)
		for i, v in ipairs(popupStack) do
			if v == frame then
				return baseY - ((i - 1) * popupSpacing)
			end
		end
		return baseY
	end

	----------------------------------------------------
	-- MW STYLE POPUP TWEEN (STACKED)
	----------------------------------------------------

	function tweenPopup(frame, lifetime)
		lifetime = lifetime or 2.5

		-- Save original size
		local originalSize = frame.Size

		-- Start state (MW style)
		frame.AnchorPoint = Vector2.new(0.5, 0.5)
		frame.Size = scaleUDim2(originalSize, 0.9)
		frame.BackgroundTransparency = 1

		-- Register into popup stack
		-- start slightly lower (for MW rise effect)
		frame.Position = ud2(0.5, 0, 1, baseY + 20)

		pushPopup(frame)

		frame:SetAttribute("Entering", true)

		local targetY = getStackY(frame)

		local duration = 0.25
		local startTime = tick()

		local connection
		connection = game:GetService("RunService").RenderStepped:Connect(function()
			if not frame.Parent then
				connection:Disconnect()
				return
			end

			local t = (tick() - startTime) / duration

			if t >= 1 then
				t = 1
			end

			local eased = 1 - (1 - t)^4

			local startY = baseY + 20
			local y = startY + (targetY - startY) * eased

			local xOffset = curveOffset(eased) * (1 - eased)

			frame.Position = ud2(0.5, xOffset, 1, y)

			if t >= 1 then
				frame:SetAttribute("Entering", false)
				connection:Disconnect()
			end
		end)

		-- Hide all text instantly
		for _, obj in ipairs(frame:GetDescendants()) do
			if obj:IsA("TextLabel") then
				obj.TextTransparency = 1
			end
		end

		-- Slide + Pop In
		local inTween = TweenService:Create(
			frame,
			TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{
				Size = originalSize,
				BackgroundTransparency = 1
			}
		)
		inTween:Play()

		-- Fade text in
		for _, obj in ipairs(frame:GetDescendants()) do
			if obj:IsA("TextLabel") then
				TweenService:Create(
					obj,
					TweenInfo.new(0.2),
					{ TextTransparency = 0 }
				):Play()
			end
		end

		-- Auto fade out after lifetime
		task.delay(lifetime, function()
			if not frame.Parent then return end

			local outTween = TweenService:Create(
				frame,
				TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
				{
					BackgroundTransparency = 1
				}
			)
			outTween:Play()

			-- Fade all text out
			for _, obj in ipairs(frame:GetDescendants()) do
				if obj:IsA("TextLabel") then
					TweenService:Create(
						obj,
						TweenInfo.new(0.25),
						{ TextTransparency = 1 }
					):Play()
				end
			end

			outTween.Completed:Wait()

			-- Remove from stack + destroy
			removePopup(frame)
			frame:Destroy()
		end)
	end

