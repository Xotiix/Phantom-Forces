	local floor = math.floor

	--------------------------------------------------
	-- rank calculator
	--------------------------------------------------

	local function rankcalculator(points)
		points = points or 0
		return floor((1/4 + points/500)^0.5 - 1/2)
	end

	--------------------------------------------------
	-- exp calculator (xp required for rank)
	--------------------------------------------------

	local function expcalculator(rank)
		rank = rank or 0
		return floor(500 * ((rank + 1/2)^2 - 1/4))
	end

	--------------------------------------------------
	-- gun price calculator
	-- linear base scaling
	-- smart early-unlock multiplier (caps at 3x)
	--------------------------------------------------

	local function gunpricecalculator(drank, playerRank)
		playerRank = playerRank or 0

		local basePrice = 1500 + 8500 * drank

		-- If player meets requirement, normal price
		if playerRank >= drank then
			return basePrice
		end

		-- Rank difference
		local rankDifference = drank - playerRank

		-- Scaled multiplier (1.5x minimum, 3x maximum)
		local multiplier = 1 + math.clamp(rankDifference / 200, 0.5, 2)

		return floor(basePrice * multiplier)
	end

	--------------------------------------------------
	-- attachment price calculator
	-- non-linear scaling
	-- early unlock multiplier (2x if below requirement)
	--------------------------------------------------

	local function attachpricecalculator(dkills, playerKills)
		playerKills = playerKills or 0

		-- Balanced scaling curve
		local basePrice = 4000 + (dkills ^ 1.25) * 0.02

		-- Early unlock tax
		if playerKills < dkills then
			basePrice = basePrice * 2
		end

		return floor(basePrice)
	end

	local function addtitle(n)
		if n <= 0 then return "0" end

		local i = math.min(math.floor(math.log10(n)/3), #abs)
		local suffix = i > 0 and abs[i] or ''
		local num = tostring(n/10^(3*i))
		local format = num:match('%d+.%d%d') or num

		return format .. suffix
	end

