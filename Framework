	local function updatecross()

		-- Crosshair spread calculation
		local speedFactor = (char.speed / 14 * (1 - 0.8) * 2 + 0.8)
		local sprintFactor = (char.sprint + 1) / 2
		local size = hud.crossspring.p * 4 * hud.crossscale.p * speedFactor * sprintFactor

		-- Clamp spread to prevent weird values
		size = math.clamp(size, 0, 40)

		-- Transparency based on spread
		local transparency = math.clamp(1 - size/20, 0, 1)

		for i = 1,4 do
			crossparts[i].BackgroundTransparency = transparency
		end

		-- Crosshair offsets
		local offset = 7

		crossparts[1].Position = ud2(0, size, 0, 0)
		crossparts[2].Position = ud2(0, -size-offset, 0, 0)
		crossparts[3].Position = ud2(0, 0, 0, size)
		crossparts[4].Position = ud2(0, 0, 0, -size-offset)

		-- Hitmarker positioning
		if hud.crossspring.t == 0 and not scopefr.Visible and sightmark and sightmark.Parent then

			local pos, onScreen = camera.currentcamera:WorldToViewportPoint(sightmark.Position)

			if onScreen then
				hitmarker.Position = ud2(0, pos.X - 124.7092, 0, pos.Y - 146.97) --0,pos.x-124.7092,0,pos.y-146.97
			else
				hitmarker.Position = ud2(0.5, -125, 0.5, -125)
			end

		else
			hitmarker.Position = ud2(0.5, -125, 0.5, -125)
		end

	end

