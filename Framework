					local function accuracycalc(mods)
						local m = mods or {}
						local d = data

						-- MW2019 philosophy:
						-- 60% recoil control, 25% bullet velocity, 15% firerate penalty

						local recoilBase =
							1 / ((m.aimcamkickmax or d.aimcamkickmax).magnitude +
								(m.aimcamkickmin or d.aimcamkickmin).magnitude) * 0.5

						local velocityBase =
							m.bulletspeed or d.bulletspeed
						velocityBase = math.clamp(velocityBase / 900, 0, 1)

						local fireratePenalty =
							(not d.variablefirerate and d.firerate or d.firerate[1]) / 900
						fireratePenalty = math.clamp(fireratePenalty, 0, 1)

						local value =
							recoilBase * 0.60 +
							velocityBase * 0.25 -
							fireratePenalty * 0.15

						return math.clamp(value, 0, 1)
					end

					local function hipcalc(mods)
						local m = mods or {}
						local d = data

						-- MW2019 philosophy:
						-- hipfire = spread stability + recoil randomness + movement penalty

						local spread = (m.hipfirespread or d.hipfirespread)
						spread = 1 / math.clamp(spread, 1, 10)

						local recoilRandom =
							((m.camkickmax or d.camkickmax) -
								(m.camkickmin or d.camkickmin)).magnitude
						recoilRandom = 1 / math.clamp(recoilRandom, 1, 10)

						local movementPenalty =
							(m.modelkickspeed or d.modelkickspeed) / 10
						movementPenalty = math.clamp(movementPenalty, 0, 1)

						local value =
							spread * 0.55 +
							recoilRandom * 0.35 -
							movementPenalty * 0.10

						return math.clamp(value, 0, 1)
					end

					local function aimcalc(mods)
						local m = mods or {}
						local d = data

						-- MW2019 philosophy:
						-- ADS = recoil stability + rotational stability + ADS speed penalty

						local recoilStability =
							1 / ((m.aimcamkickmax or d.aimcamkickmax).magnitude +
								(m.aimcamkickmin or d.aimcamkickmin).magnitude)

						local rotStability =
							1 / ((m.aimrotkickmax or d.aimrotkickmax).magnitude +
								(m.aimrotkickmin or d.aimrotkickmin).magnitude)

						local adsPenalty =
							(m.zoom or d.zoom) / 4
						adsPenalty = math.clamp(adsPenalty, 0, 1)

						local value =
							recoilStability * 0.50 +
							rotStability * 0.35 -
							adsPenalty * 0.15

						return math.clamp(value, 0, 1)
					end

					gname.Text						=data.displayname or data.name
					damage.Stat.Text				=data.damage0.." ► "..data.damage1
					damage.Stat.TextColor3			=color(1,1,1)
