	local function updatehealth()
		local health=char.health -- BOSS HEALTH


		if health>300 then player:kick("hacking") end
		healthtext.Text=health+-health%1

		blood.Size = UDim2.new(1,0,-1,100-health)
		blood.ImageRectOffset = Vector2.new(0,55-health)

		if health < prevhealth then
			local damage = prevhealth - health
			local impact = math.clamp(damage / prevhealth, 0, 1)

			-- cinematic hit response
			bloodscreen.ImageTransparency = math.clamp(
				bloodscreen.ImageTransparency - impact * 0.18,
				0,
				1
			)

			bloodscreen.BackgroundTransparency = math.clamp(
				bloodscreen.BackgroundTransparency - impact * 0.10,
				0.25,
				1
			)
		elseif health > prevhealth or health == 100 then
			-- slow cinematic recovery
			bloodscreen.ImageTransparency = math.clamp(
				bloodscreen.ImageTransparency + 0.003,
				0,
				1
			)

			bloodscreen.BackgroundTransparency = math.clamp(
				bloodscreen.BackgroundTransparency + 0.004,
				0,
				1
			)
		elseif health<=0 then
			bloodscreen.ImageTransparency=1
			bloodscreen.BackgroundTransparency=1
		end
		prevhealth=health
	end

