						cp.Value=0
						--+ reward points
						for i=1,#ppl do
							local v=ppl[i]
							if v.TeamColor==presentteam then
								local char=v.Character
								if char then
									local root=ffc(char,"HumanoidRootPart")
									if root then
										if (root.Position-base.Position).magnitude<15 and root.Position.Y>base.Position.Y then
											playerstates.addscore(v,"kingcap",200) --+ 500 is the old xp
										end
									end
								end
							end
						end
					else
						cp.Value=0
					end
				elseif not iscapping.Value then
					cp.Value=0	
				end

			end
		end
	end

	--++ round system functions

	function roundsystem:killupdate(victim,killer)

		if currentmode=="bos"then
			local kscore=killer.TeamColor==tnoobs and gscore or pscore
			local vscore=victim.TeamColor==tnoobs and gscore or pscore
			if victim.TeamColor~=tnoobs then
			gscore.Value=gscore.Value+100
			else
			pscore.Value=pscore.Value+1
			end
	
		end
		if victim==killer then return end
		local kscore=killer.TeamColor==tnoobs and gscore or pscore
		local vscore=victim.TeamColor==tnoobs and gscore or pscore
		if currentmode=="tdm" or currentmode=="koth" then
			kscore.Value=kscore.Value+1

		elseif currentmode=="dom" then
			if vscore.Value>0 then
				vscore.Value=vscore.Value-1
			end
		end
	end

	task.spawn(function()
		while true do
			if gamerunning then
				if currentmode == "dom" then
					domcheck()
				elseif currentmode == "koth" then
					kingcheck()
				end
			end
			task.wait(0.1)
		end
	end)
	
	local maplist			={"Shipment"} --"Training","Highrise","Cranehold","Snowline","Killhouse","Shipment","ShootHouse"
	
	local removalist		={"Sphere","Plane","CSGO2","Dust2","explosions","reneob","WarHome","Office","Crane","Metro","Ravod","Suburbia","Ravod2","Construction","Ruins","Warehouse","Refinery","Crane2"}

	local modelist			={"dom","koth","tdm"}
	
	--+ this is for testing modelist
	--+ local modelist ={"dom","koth","tdm"}
	
	local r					=random(1,#maplist*#modelist)

	function getmatch()
		local smode=modelist[(r-1)%#modelist+1]
		local smap=maplist[(r-1)%#maplist+1]
		r=r+1
		return smap,smode
	end

	while true do
		local mp,gm=getmatch() --+ map and mode randomizer
		print("|NOW ARRIVING "..mp.."    |GAMEMODE| "..gm)

		pcall(function()
			startmatch(mp,gm)
		end)
		task.wait(1)
	end
end
