			sparev.Value -= diff
		end
	end)

	----------------------------------------------------------------
	--++ drop gun
	----------------------------------------------------------------
	network:add("dropgun", function(name, mag, spare, spot, attachdata)
		local ref = ffc(game.StarterGui.VModel, name)
		if not ref then return end

		local ignorelist = { ignore }
		local ppl = game.Players:GetChildren()

		for i = 1, #ppl do
			if ppl[i].Character then
				ignorelist[#ignorelist + 1] = ppl[i].Character
			end
		end

		local model = ref:Clone()

		local magv = new("IntValue", model)
		magv.Name = "Mag"
		magv.Value = mag

		local sparev = new("IntValue", model)
		sparev.Name = "Spare"
		sparev.Value = spare

		local namev = new("StringValue", model)
		namev.Name = "Gun"
		namev.Value = name

		local db = new("Model", model)
		db.Name = "DB"
		debris:AddItem(db, 1)

		for i, v in next, attachdata do
			local data = new("StringValue", namev)
			data.Name = i
			data.Value = v
		end

		local params = RaycastParams.new()
		params.FilterDescendantsInstances = ignorelist
		params.FilterType = Enum.RaycastFilterType.Exclude

		local result = workspace:Raycast(spot, v3(0, -999, 0), params)

		if result then
			model.Name = "Dropped"
			model.Parent = workspace.Ignore.GunDrop
			model.Anchored = true
			model.CFrame = cf(result.Position, result.Position + result.Normal)
				* angles(0, 0, random(0, 360) * deg)
			debris:AddItem(model, 50 - #ppl)
		else
			model:Destroy()
		end
	end)

	----------------------------------------------------------------
	--++ swap gun
	----------------------------------------------------------------
	network:add("swapgun", function(player, dropped, name, mag, spare, attachdata)
		local magv = ffc(dropped, "Mag")
		local sparev = ffc(dropped, "Spare")
		local namev = ffc(dropped, "Gun")
		if not namev then return end

		local dropattach = {}
		for _, v in ipairs(namev:GetChildren()) do
			dropattach[v.Name] = v.Value
		end

		if magv and sparev then
			network:send(player, "swapgun", namev.Value, magv.Value, sparev.Value, dropattach)
		end

		local ref = ffc(game.StarterGui.VModel, name)
		if ref then
			local model = ref:Clone()

			local magv = new("IntValue", model)
			magv.Name = "Mag"
			magv.Value = mag

			local sparev = new("IntValue", model)
			sparev.Name = "Spare"
			sparev.Value = spare

			local namev = new("StringValue", model)
			namev.Name = "Gun"
			namev.Value = name

			local db = new("Model", model)
			db.Name = "DB"
			debris:AddItem(db, 1)

			for i, v in next, attachdata do
				local data = new("StringValue", namev)
				data.Name = i
				data.Value = v
			end

			model.CFrame = dropped.CFrame
			model.Name = "Dropped"
			model.Parent = workspace.Ignore.GunDrop
			model.Anchored = true
			model:BreakJoints()

			debris:AddItem(model, 60 - #game.Players:GetChildren())
		end

		dropped:Destroy()
	end)

