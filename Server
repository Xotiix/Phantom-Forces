-- event module
-- By AxisAngle (Trey Reynolds)

print("Loading event module")

do
	function event.new(eventtable)
		local self = eventtable or {}

		local functions = {}
		local removelist = {}
		local pendingdeletion = false

		------------------------------------------------------------
		--++ connect
		------------------------------------------------------------
		function self:connect(func)
			functions[#functions + 1] = func

			return function()
				if not removelist[func] then
					removelist[func] = true
					pendingdeletion = true
				end
			end
		end

		------------------------------------------------------------
		--++ fire
		------------------------------------------------------------
		return function(...)
			if pendingdeletion then
				pendingdeletion = false

				local write = 1
				for read = 1, #functions do
					local f = functions[read]
					functions[read] = nil

					if removelist[f] then
						removelist[f] = nil
					else
						f(...)
						functions[write] = f
						write = write + 1
					end
				end
			else
				for i = 1, #functions do
					functions[i](...)
				end
			end
		end, self
	end
end

















-- network module
