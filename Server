	local function applyPostFX(preset)
		local cc  = getOrCreateEffect("ColorCorrectionEffect", "MW_CC")
		local bloom = getOrCreateEffect("BloomEffect", "MW_Bloom")
		local ray = getOrCreateEffect("SunRaysEffect", "MW_Ray")
		local dof = getOrCreateEffect("DepthOfFieldEffect", "MW_DOF")

		--+ color correction
		cc.TintColor = preset.TintColor or Color3.new(1,1,1)
		cc.Contrast = preset.Contrast or 0
		cc.Brightness = preset.Brightness or 0
		cc.Saturation = preset.Saturation or 0

		--+ bloom
		bloom.Intensity = preset.BloomIntensity or 0.15
		bloom.Size = preset.BloomSize or 24
		bloom.Threshold = preset.BloomThreshold or 1
		
		--+ sunray
		ray.Intensity = preset.RayIntensity or 0.15
		ray.Spread = preset.RaySpread or 0.15

		--+ depth of field
		dof.FocusDistance = preset.FocusDistance or 60
		dof.InFocusRadius = preset.InFocusRadius or 40
		dof.NearIntensity = preset.NearIntensity or 0.05
		dof.FarIntensity = preset.FarIntensity or 0.08
	end

