	local function normalizeMapName(name)
		if not name then return nil end
		--+ strip leading underscore, trailing year, and spaces
		name = name:gsub("^_", "")      --+ "_SHIPMENT 2022" > "SHIPMENT 2022"
		name = name:gsub("%s%d+$", "")  --+ "SHIPMENT 2022" > "SHIPMENT"
		name = name:gsub("%s+", "")     --+ "Shoot House" > "ShootHouse"
		return name:lower()
	end

	local function resolveLightKey(mname)
		if not mname then
			return "Shipment" --+ safe fallback
		end

		local target = normalizeMapName(mname)

		--+ direct key match
		for key, _ in pairs(lightset) do
			if normalizeMapName(key) == target then
				return key
			end
		end

		--+ match against cfg.Name
		for key, cfg in pairs(lightset) do
			if cfg.Name and normalizeMapName(cfg.Name) == target then
				return key
			end
		end

		--+ hard fallback
		return "Shipment"
	end

