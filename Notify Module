	local function rankup(rank, newguns)
		local br = rankbar:Clone()
		br.Parent = maingui
		br.Rank.Text = "" .. rank
		br.Money.Text = "+" .. (500 + 100 * rank) .. " ♢"

		sound.play("tier_up", 2)

		popupStack = {}
		restackPopups()
		tweenPopup(br, 3)

		-- Queue gun unlock popups after rank popup ends
		if newguns then
			task.delay(3.2, function()
				for i = 1, #newguns do
					unlockedgun(newguns[i])
					task.wait(1.3)
				end
			end)
		end
	end

