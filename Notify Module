	----------------------------------------------------
	-- SAFE UDim2 SCALE HELPER
	----------------------------------------------------

	local function scaleUDim2(size, factor)
		return UDim2.new(
			size.X.Scale * factor,
			size.X.Offset * factor,
			size.Y.Scale * factor,
			size.Y.Offset * factor
		)
	end

	----------------------------------------------------
	-- MW2019 POPUP STACK SYSTEM
	----------------------------------------------------

	local popupStack = {}
	local popupSpacing = -0.11 -- vertical gap between popups
	local baseY = 0.5         -- starting Y position (bottom center)
	local maxPopups = 5

	local function restackPopups()
		for i, frame in ipairs(popupStack) do
			if frame and frame.Parent then
				local targetY = baseY - ((i - 1) * popupSpacing)

				TweenService:Create(
					frame,
					TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
					{
						Position = ud2(0.5, 0, targetY, 0)
					}
				):Play()
			end
		end
	end

	local function pushPopup(frame)
		table.insert(popupStack, frame)

		if #popupStack > maxPopups then
			local oldest = table.remove(popupStack, 1)
			if oldest then
				oldest:Destroy()
			end
		end

		restackPopups()
	end

	local function removePopup(frame)
		for i = #popupStack, 1, -1 do
			if popupStack[i] == frame then
				table.remove(popupStack, i)
				break
			end
		end
		restackPopups()
	end

	----------------------------------------------------
	-- MW STYLE POPUP TWEEN (STACKED)
	----------------------------------------------------

	local function tweenPopup(frame, lifetime)
		lifetime = lifetime or 2.5

		-- Save original size
		local originalSize = frame.Size

		-- Start state (MW style)
		frame.AnchorPoint = Vector2.new(0.5, 0.5)
		frame.Size = scaleUDim2(originalSize, 0.9)
		frame.BackgroundTransparency = 1

		-- Register into popup stack
		frame.Position = ud2(0.5, 0, baseY, 0)
		pushPopup(frame)

		-- Hide all text instantly
		for _, obj in ipairs(frame:GetDescendants()) do
			if obj:IsA("TextLabel") then
				obj.TextTransparency = 1
			end
		end

		-- Slide + Pop In
		local inTween = TweenService:Create(
			frame,
			TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
			{
				Size = originalSize,
				BackgroundTransparency = 1
			}
		)
		inTween:Play()

		-- Fade text in
		for _, obj in ipairs(frame:GetDescendants()) do
			if obj:IsA("TextLabel") then
				TweenService:Create(
					obj,
					TweenInfo.new(0.2),
					{ TextTransparency = 0 }
				):Play()
			end
		end

		-- Auto fade out after lifetime
		task.delay(lifetime, function()
			if not frame.Parent then return end

			local outTween = TweenService:Create(
				frame,
				TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
				{
					BackgroundTransparency = 1
				}
			)
			outTween:Play()

			-- Fade all text out
			for _, obj in ipairs(frame:GetDescendants()) do
				if obj:IsA("TextLabel") then
					TweenService:Create(
						obj,
						TweenInfo.new(0.25),
						{ TextTransparency = 1 }
					):Play()
				end
			end

			outTween.Completed:Wait()

			-- Remove from stack + destroy
			removePopup(frame)
			frame:Destroy()
		end)
	end

