	local function typeout(label, speed)
		label.AutoLocalize = false
		speed = speed or 2
		local str = label.Text or ""
		label.Text = ""
		task.spawn(function()
			local i = 1
			for first, last in utf8.graphemes(str) do
				label.Text ..= str:sub(first,last)
				if first > i * speed then
					sound.play("ui_typeout",0.02)
					i += 1
					task.wait()
				end
			end
		end)
	end

