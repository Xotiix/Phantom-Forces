	function menu.step()
		if run.time>lasttime+refreshint then
			menu:updatestage()
			lasttime=run.time+refreshint
			if intermission.Visible then
				intermission.Tip.Text=intermission.Tip.Text=="EN ROUTE..." and "EN ROUTE" or intermission.Tip.Text.."."
			end
		end
		intermission.Visible=not allowspawn.Value
		stage.Visible=allowspawn.Value
		menu:refreshspawn()
		if not menu:isdeployed() then
			input.mouse:show()---temporary
			--------------------------------------------------
			-- OPERATOR BUTTONS
			--------------------------------------------------
			local operatorsFrame = menugui:WaitForChild("Operators")
			local SetOperator = game.ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("SetOperator")

			local selectedFrame = nil

			for _, frame in pairs(operatorsFrame:GetChildren()) do
				local button = frame:FindFirstChild("Select")
				if button then
					button.MouseButton1Click:Connect(function()
						local operatorName = frame.Name

						-- Update the preview model
						updateOperatorPreview(operatorName)

						-- Send selection to server
						SetOperator:FireServer(operatorName)

						-- Highlight the selected operator
						if selectedFrame then
							selectedFrame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
						end
						frame.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
						selectedFrame = frame
					end)
				end
			end

			local function setpreviewfit(folder)

				for _,v in pairs(previewfit:GetChildren()) do
					if v:IsA("Shirt") or v:IsA("Pants") or v:IsA("Accessory") then
						v:Destroy()
					end
				end

				for _,v in pairs(folder:GetChildren()) do
					v:Clone().Parent = previewfit
				end

			end
		end

	end

